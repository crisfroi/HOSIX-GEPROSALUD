create table public.centros_salud (
  id uuid not null default gen_random_uuid (),
  nombre text not null,
  categoria text not null,
  provincia text not null,
  distrito text not null,
  distrito_sanitario text null,
  sector text not null,
  director text null,
  telefono text null,
  especialidades text[] null,
  estado text null default 'Activo'::text,
  created_at timestamp with time zone null default now(),
  updated_at timestamp with time zone null default now(),
  distrito_sanitario_id integer null,
  profesionales_aprobados_count integer null default 0,
  numero_registro text null,
  fecha_registro timestamp with time zone null,
  subcategoria text null,
  nif text null,
  responsable text null,
  fotos_establecimiento text[] null,
  constraint centros_salud_pkey primary key (id),
  constraint centros_salud_nombre_key unique (nombre)
) TABLESPACE pg_default;

create index IF not exists idx_centros_sector on public.centros_salud using btree (sector) TABLESPACE pg_default;

create index IF not exists idx_centros_salud_distrito_sanitario_id on public.centros_salud using btree (distrito_sanitario_id) TABLESPACE pg_default;

create index IF not exists idx_centros_nombre on public.centros_salud using btree (nombre) TABLESPACE pg_default;

create index IF not exists idx_centros_categoria on public.centros_salud using btree (categoria) TABLESPACE pg_default;

create index IF not exists idx_centros_distrito_sanitario on public.centros_salud using btree (distrito_sanitario) TABLESPACE pg_default;

create index IF not exists idx_centros_provincia on public.centros_salud using btree (provincia) TABLESPACE pg_default;

create index IF not exists idx_centros_salud_nombre_trgm on public.centros_salud using gin (nombre gin_trgm_ops) TABLESPACE pg_default;

create index IF not exists idx_centros_salud_nombre on public.centros_salud using btree (nombre) TABLESPACE pg_default;

create index IF not exists idx_centros_salud_categoria on public.centros_salud using btree (categoria) TABLESPACE pg_default;

create index IF not exists idx_centros_salud_distrito_sanitario on public.centros_salud using btree (distrito_sanitario) TABLESPACE pg_default;

create index IF not exists idx_centros_salud_provincia on public.centros_salud using btree (provincia) TABLESPACE pg_default;

create index IF not exists idx_centros_salud_distrito on public.centros_salud using btree (distrito) TABLESPACE pg_default;

