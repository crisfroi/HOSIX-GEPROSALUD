create table public.profesionales_sanitarios (
  id uuid not null default gen_random_uuid (),
  nombre_completo text not null,
  nombre text null,
  apellidos text null,
  fecha_nacimiento date null,
  edad integer null,
  genero text null,
  nacionalidad text null,
  gentilicio_femenino text null,
  domicilio text null,
  numero_dip text null,
  numero_pasaporte text null,
  telefono text null,
  area_profesional text null,
  especialidad text null,
  fecha_validez_carnet date null,
  nombre_centro text null,
  provincia text null,
  distrito text null,
  distrito_sanitario text null,
  categoria_centro text null,
  tipo_sector character varying(20) null,
  puesto_responsabilidad text null,
  estado_solicitud character varying(20) null default 'Recibido'::character varying,
  estado_trabajo character varying(50) null,
  fecha_solicitud date null,
  fecha_revision date null,
  fecha_aprobacion date null,
  motivo_rechazo text null,
  ultima_modificacion_por text null,
  titulacion_especifica_1 text null,
  tipo_formacion_1 text null,
  institucion_1 text null,
  periodo_formacion_1 text null,
  pais_formacion_1 text null,
  titulacion_especifica_2 text null,
  tipo_formacion_2 text null,
  institucion_2 text null,
  periodo_formacion_2 text null,
  pais_formacion_2 text null,
  titulo_adjunto_1 text null,
  titulo_adjunto_2 text null,
  pertenece_brigada_medica boolean null default false,
  tipo_cooperacion text null,
  brigada_cooperacion text null,
  año_inicio_paro integer null,
  meses_en_paro integer null default 0,
  codigo_expediente text null,
  url_codigo_barras text null,
  foto_carnet text null,
  url_pdf text null,
  url_carta_resolucion text null,
  pdf_formulario text null,
  copia_dip text null,
  copia_pasaporte text null,
  created_at timestamp with time zone null default now(),
  updated_at timestamp with time zone null default now(),
  creada text null,
  created_time text null,
  id_profesional_unico text null,
  fecha_alta date null,
  numero_autonumerico_correlativo integer null,
  id_distrito text null,
  fecha_creacion_solicitud timestamp without time zone null default now(),
  revisor_solicitud text null,
  urgencia_solicitud text null default 'Media'::text,
  notas_revision text null,
  periodo_formacion text null,
  año_graduacion integer null,
  categoria_titulacion text null,
  situacion_laboral text null default 'Activo'::text,
  documentos_cargados jsonb null default '[]'::jsonb,
  centro_salud_id uuid null,
  documentos_adicionales text[] null,
  fecha_emision date null default CURRENT_DATE,
  fecha_caducidad date null default (CURRENT_DATE + '1 year'::interval),
  url_carnet text null,
  url_codigo_barras_expediente text null,
  email text null,
  notas_aprobacion text null,
  fecha_rechazo text null,
  distrito_sanitario_id text null,
  funcion_publica boolean null,
  estatus_funcionario text null,
  numero_funcionario text null,
  fecha_nombramiento date null,
  fecha_inicio_trabajo date null,
  institucion_formacion_id_1 uuid null,
  fecha_generacion_resolucion date null,
  numero_tarjeta_rfid character varying(10) null,
  numero_enrolamiento_enno integer null,
  pais_formacion_id_1 bigint null,
  area_profesional_id uuid null,
  ultimo_trabajo text null,
  recien_graduado boolean null default false,
  experiencia_laboral jsonb null default '[]'::jsonb,
  tipo_profesional text null default 'sanitario'::text,
  constraint profesionales_sanitarios_pkey primary key (id),
  constraint profesionales_sanitarios_id_profesional_unico_key unique (id_profesional_unico),
  constraint profesionales_sanitarios_codigo_expediente_key unique (codigo_expediente),
  constraint fk_profesionales_centro_salud foreign KEY (centro_salud_id) references centros_salud (id) on update CASCADE on delete set null,
  constraint profesionales_sanitarios_area_profesional_id_fkey foreign KEY (area_profesional_id) references areas_profesionales (id) on delete set null,
  constraint profesionales_sanitarios_institucion_formacion_id_1_fkey foreign KEY (institucion_formacion_id_1) references instituciones_formacion (id),
  constraint fk_profesional_centro_salud foreign KEY (centro_salud_id) references centros_salud (id) on delete set null,
  constraint fk_profesional_distrito foreign KEY (distrito_sanitario) references distrito_sanitario (nombre_distrito),
  constraint profesionales_sanitarios_id_distrito_fkey foreign KEY (id_distrito) references distrito_sanitario (nombre_distrito),
  constraint fk_prof_pais_formacion foreign KEY (pais_formacion_id_1) references nacionalidades_mundo (id) on delete RESTRICT,
  constraint profesionales_sanitarios_tipo_profesional_check check (
    (
      tipo_profesional = any (
        array[
          'sanitario'::text,
          'administrativo'::text,
          'camillero'::text,
          'subalterno'::text,
          'odepac'::text,
          'otro'::text
        ]
      )
    )
  ),
  constraint profesionales_sanitarios_estado_solicitud_check check (
    (
      (estado_solicitud)::text = any (
        array[
          ('Pendiente'::character varying)::text,
          ('Aprobado'::character varying)::text,
          ('Rechazado'::character varying)::text,
          ('Revisando'::character varying)::text,
          ('Pendiente de Firma'::character varying)::text,
          ('Recibido'::character varying)::text,
          ('Rechazada'::character varying)::text
        ]
      )
    )
  ),
  constraint profesionales_sanitarios_estatus_funcionario_check check (
    (
      estatus_funcionario = any (array['nombrado'::text, 'no_nombrado'::text])
    )
  )
) TABLESPACE pg_default;

